  "_news_feeds_doc": "RSS feeds pulled on every evaluate run (15 min). Items must be younger than max_age_hours AND match at least one topic keyword before scoring. Empty list or a network failure silently skips that feed — one bad feed can't break the pipeline.",
  "news_feeds": [
    { "url": "https://www.usda.gov/sites/default/files/rss/latest-releases.xml", "source": "USDA", "max_age_hours": 48 },
    { "url": "https://www.fas.usda.gov/feeds/commodity-intelligence-reports-releases.rss", "source": "USDA FAS", "max_age_hours": 72 }
  ],

  "_news_keywords_doc": "Keyword tiers drive impact scoring for RSS items. `topic` is the filter: items without a topic word are ignored entirely. `xl|l|m` set the impact score (first tier to match wins). Lowercase-compare; edit freely.",
  "news_keywords": {
    "topic": ["corn", "soy", "soybean", "grain", "wheat", "biofuel", "ethanol", "crop", "farm"],
    "xl":    ["embargo", "export ban", "invasion", "sanction", "war declared", "tariff imposed"],
    "l":     ["tariff", "duty", "rfs", "biofuel mandate", "trade deal", "drought declared", "fomc", "rate decision", "wasde", "plantings", "stocks report", "flood", "freeze", "frost damage", "opec"],
    "m":     ["export", "import", "crop progress", "harvest", "yield", "weather", "forecast", "brazil", "argentina", "china buy", "russia", "ukraine", "drought", "rain"]
  },

  "big_move_pct": 3.0,
  "news_retention_days": 30
